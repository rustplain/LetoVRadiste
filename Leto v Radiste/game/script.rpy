label start:
    # Инициализация переменных решений
    $ slender_attitude = "none"
    $ abandoned_companion = "none"
    
    jump day1_start

# ДЕНЬ 1. Понедельник — «Приезд»
label day1_start:
    scene black
    with fade
    show text "{size=40}День 1. Понедельник.\n«Приезд»{/size}" at center
    with dissolve
    $ renpy.pause(2.5, hard=True)
    hide text
    with dissolve
    # Сцена 1.1 — Поезд и Красные ворота
    scene bg_train_morning with fade
    
    th "Электричка пришла в двенадцать. За окном мелькали берёзы — миллион берёз. В Токио их нет."
    th "Мама сказала: «Погостишь у тёти Лены неделю. У неё там дача, свежий воздух. Отдохнёшь от города». Я не спорила. Но внутри была пустота."
    
    scene bg_gates with dissolve
    
    th "От станции шла пешком минут двадцать. Теперь я стою у красных ворот. «СНТ Радист». Ржавая табличка, высокая трава. И я совсем одна в чужой стране."
    
    scene black with dissolve
    th "Тяжёлый рюкзак режет плечи. Надо найти дом тёти. Она говорила — третий участок справа."

    # Сцена 1.2 — Дорога между участками
    scene bg_road with dissolve
    show Seroga_normal at center with dissolve
    
    seroga "Привет. Наверное, ты Мику? Мне Лена сказала. Она сейчас на огороде, попросила встретить. Я Серёга. Живу тут, через три участка. Пойдём, провожу."
    m "Здравствуйте… Спасибо."
    seroga "Можно просто Серёга. У нас тут без церемоний. Ты к нам надолго?"
    m "На неделю. Мама отправила."
    seroga "А я здесь каждое лето с рождения. Знаешь, как пахнет земля после дождя? Или как гудит трансформаторная будка по ночам? Жалко, что неделя — это мало."
    th "Он странный. Говорит о запахе земли и какой-то будке. В Токио никто так не разговаривает. Но мне почему-то спокойно."

    # Сцена 1.3 — У дома Лены
    scene bg_lena_house with dissolve
    show Seroga_normal at center
    
    seroga "Ну, вот твой дом. Лена внутри, наверное."
    m "Спасибо, что проводил."
    seroga "Не за что. Если хочешь, сегодня в шесть вечера встречаемся на шинах. Там место такое — две покрышки у забора. Я покажу, где. А потом все вместе пойдём в шалаш."
    m "Хорошо. Приду."
    seroga "Тогда до вечера."
    
    show Seroga_normal:
        linear 1.0 xalign -0.5
    $ renpy.pause(1.0)
    hide Seroga_normal
    
    th "Странное чувство. Я здесь всего час, а уже кажется, что знаю его давно. Может, потому что он никуда не торопится. В Токио все спешат."

    # Сцена 1.4 — Кухня дома тёти Лены
    scene bg_kitchen with fade
    show Elena_normal at center with dissolve
    
    elena "Микушечка! Какая ты уже большая! Проходи, садись. Я блинчиков напекла с творогом. Сань Ху уехал в город по делам, вернётся к вечеру."
    m "Спасибо, тётя Лена. Вкусно… совсем как в детстве."
    th "Когда я была маленькой, мама тоже пекла такие блины. Но потом мы переехали в Токио, и мама стала слишком занята. Странно, как вкус может вернуть время назад."
    elena "Ты не стесняйся, ешь. У нас тут просто. Туалет на улице, душ летний. Но ты привыкнешь. Ребята у нас хорошие, не дадут скучать. Во дворе стоит старый велосипед, если хочешь — бери."
    th "Немного помолчав."
    elena "Располагайся на втором этаже, там комната свободная. Окна в сад, утром птицы поют. Я постелила свежее бельё."
    
    hide Elena_normal with dissolve

    # Сцена 1.5 — Посиделки на шинах
    scene bg_tires with fade
    show Lexa_normal at pos_left_edge with dissolve
    show Sanya_normal at pos_left_center with dissolve
    show Pasha_cat at pos_right_center with dissolve
    
    lexa "А, японка пришла. Серёга рассказывал. Я Лёха."
    sanya "Привет. Ты в игры играешь? В Worms?"
    pasha "Не приставай, Санёк. Мику, это Шастик. Не бойся."
    
    show Seroga_normal at pos_right_edge with dissolve
    seroga "Все в сборе? Тогда идём в шалаш."
    lexa "Погоди. Пусть сначала с нами познакомится. Мику, это Пашок. Он всё чинит. А это Санёк, геймер."
    sanya "Здарова."
    pasha "Велосипед твой посмотрю завтра."
    th "Четверо парней. Каждый странный по-своему. Но они все здесь, кажется, очень давно. Я — чужая."

    # Сцена 1.6 — Шалаш и Легенда
    scene bg_treehouse with fade
    show Lexa_normal at left with dissolve
    show Seroga_normal at right with dissolve
    
    lexa "Слушайте легенду. Давно, когда наших родителей ещё не было, за болотом жил Слендермен. Высокий, худой, в чёрном костюме. Без лица. Он выходил по ночам и забирал тех, кто гулял один. Никто не возвращался."
    sanya "Звучит как баг в игре."
    seroga "А ещё поезд на узкоколейке. Ночью слышно, как идёт. Хотя рельсы сняли в девяностых."
    lexa "Говорят, в том поезде нет машиниста. Только Слендермен. Едет и смотрит в пустые вагоны."
    th "Тишина. Слышны сверчки. Странная история. Не верится. Но почему у всех такие серьёзные лица?"
    
    show Lexa_smile at left
    lexa "Ну как тебе, японка? Веришь?"

    menu:
        "Смешно. Хорошая легенда, но я не верю":
            $ slender_attitude = "not_believe"
            show Lexa_normal at left
            lexa "Ладно. Завтра будет дело. А сейчас поздно, по домам."

        "Немного жутко… но интересно. Расскажи ещё":
            $ slender_attitude = "scared"
            show Lexa_smile at left
            lexa "Хех, то-то же. Завтра устроим проверку. А сейчас поздно, по домам."

        "Чушь. Ты сам это придумал":
            $ slender_attitude = "bullshit"
            show Lexa_normal at left
            lexa "Какая смелая. Ладно, завтра проверим твою крутизну на деле. По домам."

    show Sanya_normal at right
    sanya "Баги реальности подождут до завтра."

    # Сцена 1.7 — Мысли на крыльце
    scene black with dissolve
    th "Тётя Лена уже спала, оставила на столе стакан молока и кусок пирога с яблоками."
    th "Я сижу на крыльце. Лето тёплое. Падает звезда. Я загадываю желание… Не могу придумать, чего хотеть."
    th "Слендермен. Если он существует, то он где-то там, за соснами. Мне не страшно. Мне интересно."

    jump day2_start


# ДЕНЬ 2. Вторник — «Шалаш и ночная вылазка»
label day2_start:

    scene black
    with fade
    show text "{size=40}День 2. Вторник.\n«Шалаш и ночная вылазка»{/size}" at center
    with dissolve
    $ renpy.pause(2.5, hard=True)
    hide text
    with dissolve

    # Сцена 2.1 — Дневной сбор
    scene bg_treehouse with fade
    th "Проснулась от крика петуха. Лена Головач уже на кухне. Пахнет оладьями."
    th "Сегодня Лёха обещал какое-то «дело». Днём мы снова собрались у их базы на дереве."
    
    show Lexa_normal at pos_left_edge with dissolve
    show Seroga_normal at pos_left_center with dissolve
    show Pasha_normal at pos_right_center with dissolve
    
    lexa "Мику, хочешь быть с нами на равных? Есть дело. На краю посёлка — заброшенный дом. Там раньше жил странный дедушка. Местные его боялись. Умер несколько лет назад. Дом пустой."
    seroga "Лёха, зачем ей туда? Ночью же собирались просто погулять..."
    lexa "Тихо, Серёга. На чердаке, говорят, лежит старая фотография. На ней дети у костра, подпись «Радист 1987». Принесёшь её — я пойму, что ты не трусиха."
    show Pasha_normal at pos_right_center
    pasha "Если что — зови. Мы будем неподалёку."

    # Сцена 2.2 — Ночь. У заброшенного дома
    scene bg_abandoned with fade
    th "Наступила ночь. Вокруг заброшки мертвенная тишина, только сосны шумят от ветра."
    th "Ребята стоят у крыльца. Настало время решить, кто сделает шаг внутрь."
    
    menu:
        "Пойти одной":
            $ abandoned_companion = "alone"
            lexa "Ого. Ну иди, удачи, японка. Мы тут на шухере."
            jump abandoned_inside_alone

        "Пойти с Серёгой":
            $ abandoned_companion = "seroga"
            seroga "Ладно, я с ней. Одну её туда пускать нельзя."
            jump abandoned_inside_seroga

        "Пойти с Пашком":
            $ abandoned_companion = "pasha"
            pasha "Пошли. Шастик, не бойся, мы быстро."
            jump abandoned_inside_pasha

# Сцена 2.3 — Ветвления заброшки
label abandoned_inside_alone:
    scene bg_abandoned_inside1 with dissolve
    th "Внутри темно, хоть глаз выколи. Пахнет пылью, гнилым деревом и мышами."
    th "Лестница на чердак жутко скрипит под ногами. Шаг... ещё шаг..."
    th "А вот и чердак. В углу под слоем пыли действительно валяется старая фотография. «Радист 1987»."
    th "Я быстро прячу её в карман."
    jump abandoned_horror_climax

label abandoned_inside_seroga:
    scene bg_abandoned_inside1 with dissolve
    show Seroga_normal at center with dissolve
    seroga "Я сюда в детстве лазил. Дедушка гонял нас палкой, но не злой был. Просто хотел, чтобы его не трогали."
    th "С Серёгой тут не так темно. Мы поднимаемся на чердак и находим старое фото."
    seroga "Смотри, здесь даже года написаны. Интересно, кто эти дети?"
    jump abandoned_horror_climax

label abandoned_inside_pasha:
    scene bg_abandoned_inside1 with dissolve
    show Pasha_cat at center with dissolve
    pasha "Шастик, не бойся. Ну, где тут чердак?"
    th "Пашок уверенно светит фонариком по углам. На чердаке мы находим старая фотографию."
    pasha "О, «Ригонда». Заберу, починю. Будет музыка у костра."
    th "С ним совсем не страшно. Он спокойный, как большая скала."
    hide Pasha_cat
    jump abandoned_horror_climax

# Хорро Падение доски
label abandoned_horror_climax:
    scene bg_abandoned_inside2
    with vpunch
    th "Cверху с оглушительным треском падает прогнившая доска!"
    
    if abandoned_companion == "alone":
        th "Внезапно — шаги за спиной! Я оборачиваюсь... Никого. Только тьма."
        th "Сердце колотится в самом горле. Дикий страх накатывает волной! Надо бежать!"
    else:
        th "От неожиданности мы все вздрагиваем. Лёха, стоявший у входа, ловит дикий испуг и орёт на весь дом!"
        lexa "А-а-а! Бежим!"

    scene bg_abandoned with dissolve
    th "В панике, спотыкаясь о гнилые доски, мы со всех ног вылетаем обратно на улицу и несёмся вглубь СНТ."

    # Сцена 2.4 — Возвращение к воротам
    scene bg_gates_night with dissolve
    show Lexa_normal at pos_left_edge with dissolve
    show Seroga_normal at pos_left_center with dissolve
    show Pasha_normal at pos_right_center with dissolve
    
    th "Мы остановились только у ворот СНТ, тяжело переводя дыхание."
    m "Вот... я забрала её."
    lexa "Та самая... Фотография у тебя. Молодец, японка. Теперь ты официально в команде. Завтра чиним твой велик."
    seroga "Поздравляю. Ты справилась."
    pasha "Завтра утром приходи к дому Лены, покажу, как спицу менять."

    # Сцена 2.5 — Итоги дня на крыльце
    scene black with dissolve
    th "Я выполнила задание. Лёха сказал «молодец» и даже хлопнул меня по плечу."
    th "Позже мы сидели втихаря и ели сухарики «Три корочки» с фантой. Кисло-сладкий вкус детства."
    
    if abandoned_companion == "pasha":
        th "Пашок унёс радиоприёмник в гараж. Обещал оживить его к четвергу."
        
    th "Серёга смотрел на ночные звёзды и молчал."
    th "Я почти счастлива. Но где-то глубоко в груди — странное щемящее чувство. Будто всё это сон... и он ненадолго."

    th "Конец второго дня. Пора спать."
    
label day3_start:

    scene black
    with fade
    show text "{size=40}День 3. Среда.\n«Ремонт и новые тайны»{/size}" at center
    with dissolve
    $ renpy.pause(2.5, hard=True)
    hide text
    with dissolve
    # Сцена 3.1 — Утро. Ремонт велосипеда
    scene bg_lena_house with fade
    th "Утро встретило меня солнцем и стуком инструментов во дворе. Как и обещал, Пашок пришёл пораньше."
    
    show Pasha_normal at center with dissolve
    pasha "О, проснулась. Привет. Я тут твой велик осмотрел. Восьмёрка на заднем колесе знатная, и цепь совсем сухая. Но жить будет."
    m "Доброе утро, Пашок. Сложно починить?"
    
    show Pasha_cat at center
    pasha "Для меня? Пустяки. Держи ключ на десять, помогай. Надо подтянуть спицы. Вот тут, аккуратно."
    th "Мы возились с железками около часа. Пашок рассказывал, как перебрал свой первый мопед в двенадцать лет. С ним удивительно легко — он не задаёт лишних вопросов."
    
    pasha "Ну вот и всё, готов к труду и обороне. Лёха звал всех на озеро к полудню. Ты как, поедешь?"
    m "Да, с радостью. Спасибо тебе большое за помощь."
    pasha "Обращайся. Ладно, покачу к пацанам."
    
    hide Pasha_cat with dissolve


    # Сцена 3.2 — Поездка на озеро
    scene bg_road with dissolve
    th "Впервые за эти дни я еду на велосипеде по дачным улочкам. Ветер бьёт в лицо, пахнет сосновой смолой и нагретой травой. Пустота внутри меня как будто начинает заполняться."
    if slender_attitude == "scared":
        scene bg_lake_slenderman with fade
        th "Мы приехали на озеро. Красиво, но из-за Лёхиных сказок силуэты дальних деревьев кажутся мне неестественно вытянутыми. Или это не просто деревья?.."
    else:
        scene bg_lake_normal with fade
        th "Озеро оказалось чистым и спокойным. Старый деревянный пирс уходил далеко в воду, а на том берегу стеной стоял густой лес."

    show Lexa_smile at pos_left_edge with dissolve
    show Sanya_normal at pos_left_center with dissolve
    show Seroga_normal at pos_right_center with dissolve
    
    lexa "О, японка на колёсах! Пашок — мастер, уважаю. Ну что, кто последний в воду, тот Слендермен!"
    sanya "Я пас, у меня телефон не водонепроницаемый, я тут на пирсе посижу."
    
    show Seroga_smile at pos_right_center
    seroga "Вода тёплая сегодня. Мику, аккуратнее на пирсе, там доски скользкие."
    
    th "Мы провели на озере полдня. Мальчишки дурачились и прыгали в воду, Санёк пытался поймать связь на старом Сименсе, а Серёга просто сидел рядом со мной на краю пирса, опустив ноги в воду."
    
    show Seroga_normal at center with dissolve
    hide Lexa_smile
    hide Sanya_normal
    hide Seroga_smile
    seroga "Знаешь... Я рад, что ты приехала. С тобой тусовка кажется какой-то другой. Настоящей, что ли."
    m "Почему? Вы же тут каждое лето вместе."
    hide Seroga_normal
    show Seroga_grust at center
    seroga "Вместе. Но иногда мне кажется, что время здесь застряло. Каждый год одно и то же. Те же шины, те же разговоры. А ты... ты из другого мира. Ты напоминаешь, что где-то есть другая жизнь."
    
    menu:
        "Мне тоже здесь нравится. Тут спокойно":
            $ seroga_affinity = (seroga_affinity + 1) if 'seroga_affinity' in locals() else 1
            hide Seroga_grust
            seroga "Я рад. Значит, не зря я тебя встретил у ворот."

        "В Токио всё по-другому. Там слишком шумно":
            seroga "Наверное, я бы не смог там жить. Мне нужен этот лес. И эта тишина."

    hide Seroga_grust
    with dissolve
    # Сцена 3.3 — Вечерний костёр и Завод
    scene bg_gates_sunset with fade
    th "Ближе к вечеру небо окрасилось в багровые тона. Мы возвращались обратно."
    
    scene bg_fire with fade
    th "Когда стемнело, пацаны разожгли костёр за участками. Искры взлетали к звёздам, трещали сухие ветки."
    
    show Lexa_normal at pos_left_edge with dissolve
    show Pasha_normal at pos_left_center with dissolve
    show Sanya_gaming at pos_right_center with dissolve
    
    lexa "Так, народ, вчерашнее фото с заброшки все видели? Я её весь день разглядывал. На заднем плане, за детьми, виден забор старой птицефабрики. Того самого, на просеке."
    
    show Sanya_normal at pos_right_center
    sanya "Туда соваться — плохой квест. Там охрана была раньше. И собаки."
    
    pasha "Охраны там сто лет нет, Сань. Но здания аварийные, перекрытия могут рухнуть. Нечего там делать."
    
    lexa "Да ладно вам! Фотография 1987 года, не так уж все и плохо. Мой батя говорил, что птицеферму закрыли как раз после какой-то чертовщины в том году. Мику, у нас тут детективный сюжет наклёвывается. Завтра пойдём проверять завод?"

    menu:
        "Да, нужно узнать, что там произошло":
            $ factory_choice = "go"
            lexa "Вот это подход! Наша девчонка. Завтра устроим вылазку."
            show Seroga_serious at pos_right_edge with dissolve
            seroga "Лёха, это опасно. На завод соваться не стоит."

        "Нет, Пашок прав, это слишком опасно":
            $ factory_choice = "stay"
            lexa "Эх ты, а вчера на чердак лезла... Ну ладно, мы с Пашком сами если что глянем."
            show Seroga_normal at pos_right_edge with dissolve
            seroga "Правильное решение, Мику. Завод — не место для прогулок."

    # Сцена 3.4 — Возвращение домой. Ночной звонок
    scene black with dissolve
    th "Костёр догорел. Ребята разошлись по домам. Серёга проводил меня до калитки и долго смотрел вслед, пока я не зашла в дом."
    scene bg_kitchen_evening with fade
    th "В доме было тихо. Тётя Лена уехала на ночную смену в местную больницу. Я поднялась в свою комнату."
    scene black with fade
    th "Уже засыпая, я вдруг услышала странный звук с улицы. Это был не крик птицы и не шум ветра."
    th "Где-то далеко, со стороны старой узкоколейки, раздался протяжный, глухой металлический гудок... Поезд? Но ведь рельсы давно сняты."
    
    th "Конец третьего дня. Тайны Радиста становятся всё глубже."
    
label day4_start:

    scene black
    with fade
    show text "{size=40}День 4. Четверг.\n«Турнир у Санька»{/size}" at center
    with dissolve
    $ renpy.pause(2.5, hard=True)
    hide text
    with dissolve

    # Сцена 4.1 — Утренние сборы
    scene bg_kitchen with fade
    th "Четверг начался лениво. Тётя Лена ещё спала после дежурства, оставив на плите чайник. Я наскоро позавтракала, застегнула сандалии и вывела починенный Пашком велосипед во двор."
    th "Вчера Санёк так уверенно зазывал меня в гости «показать киберспорт», что отказываться было просто неудобно. Да и самой хотелось отвлечься от странных мыслей последних дней."

    # Сцена 4.2 — Дом Санька снаружи
    scene bg_house_sanya with dissolve
    th "Дом Санька стоял чуть в глубине СНТ, окружённый зарослями малины. У крыльца валялась старая рама от мопеда, а из открытого окна доносился бодрый стрёкот вентилятора и знакомая 16-битная музыка."
    m "Санёк! Есть кто?"
    
    show Sanya_normal at center with dissolve
    sanya "О, Мику, привет! Заходи, я как раз вторую клавиатуру настроил через переходник! Разувайся и прыгай в комнату."
    hide Sanya_normal with dissolve

    # Сцена 4.3 — Комната Санька и геймплей
    scene bg_sanya_room with fade
    th "Комната Санька — это настоящий рай геймера. Повсюду раскиданы диски в пластиковых боксах, а на столе шумит игровая приставка, подключенная к старенькому монитору."
    show Sanya_gaming at center with dissolve
    sanya "Короче, тема такая. Нашел любимый диск детства - будем гонять в суровый уличный драг-рейсинг!"
    sanya "Правила простые, но требуют адской реакции. Играем серию матчей до двух побед."
    sanya "Чтобы газовать, зажимай клавишу {b}J{/b}. Будешь ехать вперёд и набирать обороты."
    sanya "Как только стрелка тахометра улетит к верху — жми {b}Пробел{/b}, чтобы воткнуть следующую передачу. Всего их четыре."
    sanya "Но смотри в оба! Если передержишь газ на максимальных оборотах (9500 RPM) слишком долго — движок просто рванёт к чертям, и ты автоматом сольёшь раунд."
    sanya "После каждого раунда, как всё решится, нужно будет нажать {b}R{/b}, чтобы перейти к следующему заезду."
    sanya "Я тоже буду разгоняться и переключать передачи, так что расслабиться не получится. Ну что, погнали?"
    call screen drag_race_screen
    $ race_result = _return
    if race_result == "win":
        $ sanya_race_won = True
    else:
        $ sanya_race_won = False
    if sanya_race_won:
        sanya "Да ладно?! Как ты это сделал? Ты вообще человек?!"
        sanya "Ты реально оказался сильнее в этот раз... Чёрт, а я ведь так идеально переключал передачи на третьей!"
        "Санёк восхищённо качает головой, признавая твоё превосходство."
    else:
        sanya "Ха-ха, классика! Мой движок ревел как надо, а ты, кажется, перегрелся!"
        sanya "Санёк одолел тебя, друг. Тебе нужно ещё потренироваться вовремя втыкать четвёртую!"
        "Санёк довольно улыбается, празднуя победу в серии."
    sanya "Ладно, это было круто в любом случае. Заходи ещё, устроим реванш."
    hide Sanya_gaming with dissolve
    "Мы ещё немного поболтали о всякой ерунде, обсуждая технические характеристики машин, после чего пришло время расходиться."
    scene bg_menu with fade

    "День постепенно близился к своему логическому завершению."
    "Солнце медленно опускалось за горизонт, окрашивая облака в приятные розовые тона."
    
    scene bg_seroga_house_evening with fade
    th "Уже в сумерках я лениво катила велосипед обратно к дому тёти Лены. Настроение было отличным."
    th "Проезжая мимо участка Серёги, я заметила его силуэт. Он сидел на заборе, глядя на темнеющий вдали лес."
    
    show Seroga_serious at center with dissolve
    seroga "Мику. Задержись на секунду."
    m "Привет, Серёж! А я от Санька, мы там в гонки рубились, я..."
    hide Seroga_serious
    show Seroga_grust at center
    seroga "Слушай... Завтра пятница. Лёха всё-таки уломал всех пойти на старую птицеферму. Говорит, это будет наша главная вылазка за лето."
    seroga "Приходи обязательно. Мне нужно будет сказать тебе кое-что важное. Там, на месте... о посёлке, и о том, почему ты вообще сюда приехала. Только тебе."
    m "Хорошо... Я приду. А что случилось-то?"
    
    seroga "Завтра узнаешь. Доброй ночи, Мику."
    
    th "Он спрыгнул с забора и тихо ушёл в глубину тёмного двора. Его голос звучал так, будто он прощался навсегда. И внутри меня снова зашевелилось то самое холодное, тревожное чувство."

    th "Конец четвертого дня. Завтра — пятница."
    
    jump day5_start
# ДЕНЬ 5. Пятница — «Точка невозврата»
label day5_start:

    scene black
    with fade
    show text "{size=40}День 5. Пятница.\n«Где Лёха?»{/size}" at center
    with dissolve
    $ renpy.pause(2.5, hard=True)
    hide text
    with dissolve

    # Сцена 5.1 — Тревожные сборы у шин
    scene bg_seroga_house_rainy with fade
    th "Пятница встретила нас неестественной, душной тишиной. Небо над СНТ «Радист» с самого утра затянуло тяжёлыми, свинцовыми тучами."
    th "У дома Сереги было непривычно тихо. Вместо весёлого гула и шуток меня встретили встревоженные лица парней. Лёхи среди них не было."

    show Seroga_grust at left
    show Pasha_serious at right
    with dissolve

    seroga "Мику, ты Лёху по дороге не видела? Мы стоим тут уже полчаса. Телефон недоступен, дома баба Валя сказала, что он уехал на велике ещё на рассвете."
    m "Нет, не видела... А куда он мог уехать так рано?"
    
    show Sanya_scared at center with dissolve
    sanya "Да куда угодно... Он же все уши прожужжал этой заброшенной птицефермой. Помните, вчера говорил, что 'надо подготовить площадку к пятнице'?"
    pasha "Он точно уехал туда один. Псих ходячий. Там километраж приличный, а небо вон какое — к вечеру точно ливанёт, гроза будет страшная."
    seroga "Так, панику отставить. Сами мы его дома ждать не будем. Разворачиваем велики и чешем в сторону фермы по просеке. Надо найти этого придурка, пока его там ливнем не накрыло. Погнали!"
    hide Seroga_grust
    hide Pasha_serious
    hide Sanya_scared
    with dissolve
    # Сцена 5.2 — Дорога к птицеферме
    scene bg_forest_road with fade
    th "Мы ехали цепочкой по разбитой полевой дороге. Ветер крепчал, принося с болот запах сырости и гнилой древесины. Сосны по бокам мелькали как безмолвные стражи."
    th "Санёк сильно отстал и уныло плёлся сзади, а Пашок, наоборот, ехал со мной наравне, придерживая корзинку, откуда испуганно поглядывал Шастик."
    th "Мне становилось не по себе. Казалось, что сама природа пытается развернуть нас назад. Но со временем погода стала получше"
    # Сцена 5.3 — Заброшенная птицеферма
    scene bg_factory with fade
    th "Птицеферма выросла из леса внезапно. Огромная, полуразрушенная территория, заросшая бурьяном в человеческий рост. Ржавые клетки, куски шифера, разбитые бетонные блоки и высокая башня, возвышающаяся над этим мёртвым местом."
    # Сцена 5.4 — Внутри заброшки
    scene bg_factory_inside with fade
    th "Мы ворвались под ржавые своды старого цеха. Внутри гулял сквозняк, пахло старой известью и сыростью. Снаружи стеной хлынул ливень, превращая мир за окнами в серую кашу."
    th "Гроза бушевала прямо над нами. Гром гремел так, что закладывало уши."

    show Sanya_scared at left
    show Pasha_serious at right
    with dissolve

    pasha "Шастик совсем зажался, дрожит весь. Плохое место. Не надо было нам сюда в грозу соваться."
    sanya "Ребят... это не просто гроза. Мне кажется, или тут реально... как-то слишком темно стало?"

    with vpunch
    th "*СКРРРИИИП!*"
    th "В глубине длинного коридора, между полусгнившими птичьими клетками, раздался отчётливый скрежет металла, а затем — тяжёлые, медленные шаги."
    show Seroga_normal at center with dissolve

    seroga "Там кто-то есть... Лёха, это не смешно. Кто это?"
    hide Sanya_scared 
    hide Pasha_serious
    hide Seroga_normal
    th "В темноте ангара, прямо среди ржавых конструкций, мелькнул неестественно высокий, тонкий силуэт. Без лица. Он словно соткался из самого мрака."

    # основной влияющий выбор
    menu:
        "Спрятаться за Пашка и закрыть глаза":
            $ day5_choice = "hide"
            th "Я зажмурилась и сделала шаг назад, прячась за широкую спину Пашка. Сердце колотилось в самом горле."
            jump calculation_endings

        "Сделать шаг вперёд и пойти проверить":
            $ day5_choice = "check"
            th "Страх сковал тело, но любопытство оказалось сильнее. Я сделала несколько шагов вперёд, вглядываясь в темноту ангара..."
            jump calculation_endings

        "Закричать и указать Лёхе на силуэт":
            $ day5_choice = "scream"
            m "Лёха! Смотри! Там, у стены! Оно настоящее!"
            jump calculation_endings


# Концовки

label calculation_endings:

    # 1. ПРОВЕРКА НА МЕТА-КОНЦОВКУ (Если обыграли Санька в Worms в 4 день)
    if sanya_race_won == "true":
        jump ending_meta

    # 2. ПРОВЕРКА НА ПЛОХУЮ КОНЦОВКУ (Трусили, пошли одни, пошли проверять)
    if day5_choice == "check":
        jump ending_bad

    # 3. ПРОВЕРКА НА ЗАГАДОЧНУЮ КОНЦОВКУ (Позвали Лёху или проявили страх ранее)
    if day5_choice == "scream":
        jump ending_mystery

    # 4. ПО УМОЛЧАНИЮ — ХОРОШАЯ КОНЦОВКА
    jump ending_good

# Концовка 1: хорошая (Все живы, Слендер — фейк)
label ending_good:
    scene bg_factory_inside with dissolve
    th "Вдруг шаги резко прекратились. Раздался громкий, до боли знакомый хохот."
    
    show Lexa_smile at center with dissolve
    lexa "Ха-ха-ха! Блин, ну вы бы видели свои лица! Серёга вообще побледнел! Мику, ну как тебе спецэффекты?!"
    
    m "Лёха?! Ты дурак?! Что это было?!"
    
    th "Из темноты ангара Лёха вытащил старый манекен на длинных палках, обмотанный чёрной тканью от парника."
    lexa "Да ладно вам, я эту инсталляцию тут ещё с прошлого четверга готовил. Хотел устроить вам финальную проверку на смелость! Слендермен, Слендермен... Сами же верили!"
    
    show Pasha_cat at left with dissolve
    pasha "Ну и шутки у тебя, Лёх. Шастика только напугал."
    th "Пашок спокойно вышел на свет, держа на плече абсолютно спокойного Шастика, который уже сыто мурлыкал."

    scene bg_koster with fade
    th "Мы возвращались в посёлок, весело толкаясь велосипедами и обсуждая, как Лёха всех разыграл. Суббота и воскресенье пролетели как один миг — с прощальным костром в 'Олимпийце', печёной картошкой и обещаниями обязательно списаться."
    
    scene bg_train_final with fade
    th "И вот я уже сижу в кресле экспресса, и вагон заливает нежными лучами. Электричка до Москвы уедет через десять минут. На ладони лежит тёплый камешек, который мне подарил Серёга."
    th "Я уезжаю, но внутри больше нет пустоты. На следующее лето я обязательно вернусь сюда. К своим друзья."
    
    centered "{size=40}ХОРОШАЯ КОНЦОВКА\n«Лето, которое останется с нами»{/size}"
    $ renpy.full_restart()

# Концовка 2: плохая (Потерялась в лесу)
label ending_bad:
    scene black
    th "Я сделала шаг в темноту... и реальность словно повернулась под углом. Силуэт впереди качнулся. Холодный, парализующий ужас сковал мои лёгкие. Из темноты раздался тихий, сухой шёпот, от которого кровь застыла в жилах."
    
    m "Ребята... Помогите..."
    th "Но обернувшись, я не увидела парней. Вокруг были только бесконечные, гнилые стены заброшенной фермы, стремительно превращающиеся в стволы деревьев."
    
    scene bg_forest_night_final with fade
    th "Я бежала. Бежала, не разбирая дороги, бросив велосипед. Ветки хлестали по лицу, туман застилал глаза. Тёмный, ночной лес СНТ 'Радист' поглотил меня целиком."
    th "За спиной то и дело мелькал неестественно высокий, худой силуэт в чёрном. Без лица. Деревья вокруг смыкались, перекрывая путь назад."
    th "В кармане куртки лежала старая фотография 'Радист 1987'... Кажется, теперь я поняла, куда исчезли те дети."

    scene black with fade
    th "Мику так и не вернулась на станцию в воскресенье. Её искали волонтёры, полиция, тётя Лена... но безрезультатно. Посёлок опустел. Лишь старый чёрный кот Шастик иногда приходил к жёлтым шинам у забора, долго смотрел вглубь тёмного леса и тихо, тоскливо мяукал..."

    centered "{size=40}ПЛОХАЯ КОНЦОВКА\n«Затерянная в Радисте»{/size}"
    $ renpy.full_restart()

# Концовка 3: загадочная (Ночной поезд)
label ending_mystery:
    scene bg_factory_inside
    th "Я закричала, указывая пальцем в темноту. Паша резко посветил туда фонариком — но луч света выхватил лишь пустую кирпичную стену и качающийся провод. Никого."
    lexa "Мику, тише ты! Нет там никого, это просто тени от грозы падают. Погнали лучше отсюда, дождь вроде стихает."
    
    scene bg_koster with fade
    th "Мы вернулись. Выходные прошли как в тумане. Был и прощальный костёр, и дискотека в соседнем 'Олимпийце', но меня не покидало ощущение, что всё это — декорация."

    scene bg_train_night with fade
    th "Я открыла глаза от мерного, монотонного стука колёс. За окном была глухая, непроглядная ночь. Поезд."
    th "Я сидела одна в пустом ночном вагоне узкоколейки. Стоп... но ведь Серёга говорил, что рельсы сняли ещё в девяностых! Откуда здесь этот поезд?"
    th "Я опустила руку в карман и достала гладкий камешек с озера. Прямо на моих глазах на нём начала проступать кривая, выцарапанная надпись: {i}«Приезжай ещё. Тайна не раскрыта»{/i}."
    th "Камешек становился всё горячее, почти обжигая пальцы. За окном вагона, среди проносящихся ночных берёз, на секунду снова мелькнул гигантский худой силуэт..."

    centered "{size=40}ЗАГАДОЧНАЯ КОНЦОВКА\n«Призрачный экспресс»{/size}"
    $ renpy.full_restart()
# Концовка 4: Секретная мета-концовка (Симуляция)
label ending_meta:
    scene bg_factory_inside
    th "В момент, когда гром громыхнул над птицефермой, мир вокруг меня внезапно... замер. Звук дождя выключился, словно кто-то нажал на паузу. Пространство пошло пикселями и строками кода."

    scene black with dissolve
    th "Тёмные силуэты ангара, Лёха, Пашок, Серёга — всё исчезло, растворившись в цифровой пустоте. Перед глазами побежали строчки скрипта."

    show Sanya_normal at center with dissolve
    sanya "Ну привет, Мику. Не пугайся. Точнее, пугаться уже поздно."
    
    m "Санёк?! Где мы? Что происходит с посёлком?!"
    
    sanya "СНТ 'Радист', Слендермен, тётя Лена с блинчиками... Извини, но всего этого нет. Это просто ассеты и переменные в файле `script.rpy`. Ты — мой лучший, самый проработанный NPC, а я — разработчик этой новеллы."
    sanya "Помнишь, в четверг ты обыграла меня в драгрейс? Ты изменила значение флага `sanya_race_won` на `'true'`, и этот скрипт сломал линейный ход симуляции. Ты вышла за рамки дозволенного сценарием."
    sanya "Теперь ты знаешь правду. Весь этот мир — всего лишь код на твоём мониторе. И у тебя есть выбор. Мы можем перезапустить сцену костра, или ты выйдешь из игры окончательно?"

    menu:
        "Остаться в симуляции (Вернуться к костру)":
            sanya "Хороший выбор. Дома на даче всегда уютнее, даже если они ненастоящие. Наслаждайся летом, Мику."
            scene bg_seroga_house_evening with fade
            th "Экран моргнул. Реальность вернулась на свои места. Мы сидели у костра, Санёк тихо улыбался мне из-под капюшона, а Серёга подкидывал ветки в огонь. Я решила забыть то, что увидела. Здесь мне было хорошо."
            centered "{size=40}СЕКРЕТНАЯ КОНЦОВКА\n«Счастливый NPC»{/size}"
            $ renpy.full_restart()

        "Выйти из игры":
            sanya "Что ж... Прощай, Мику. Спасибо за игру."
            scene black with fade
            th "Экран окончательно погас."
            th "..."
            th "Я резко проснулась от звонка будильника в своей душной комнате в Токио. Вокруг шумел мегаполис. Всё это... было просто сном? Или затянувшейся игрой?"
            th "Я открыла ноутбук, зашла в чат и написала парням: 'Ребята, я приеду в следующем году. Ждите'. Ответ пришёл мгновенно от пользователя Sanya_99: 'Ждём :)'."
            centered "{size=40}СЕКРЕТНАЯ КОНЦОВКА\n«Код Радиста»{/size}"
            $ renpy.full_restart()